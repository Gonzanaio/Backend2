
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Perfil</title>
  <style>
    body {
      margin: 0;
      min-height: 100vh;
      background: linear-gradient(135deg, #020617, #1e40af);
      font-family: Arial, Helvetica, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      color: #e5e7eb;
    }

    .card {
      background: #29397c;
      padding: 2.5rem;
      border-radius: 16px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 12px 28px rgba(0,0,0,.45);
    }

    h1 {
      text-align: center;
      margin-bottom: 1.5rem;
      color: #ffffff;
    }

    .row {
      margin-bottom: .7rem;
      font-size: .95rem;
    }

    .label {
      color: #ffffff;
      font-weight: bold;
    }

    .actions {
      margin-top: 1.5rem;
      display: flex;
      justify-content: space-between;
    }

    .actions a {
      color: #60a5fa;
      text-decoration: none;
      font-size: .9rem;
    }

    .actions a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="card">
    <h1>Perfil</h1>

    <div class="row"><span class="label">Nombre:</span> {{user.first_name}} {{user.last_name}}</div>
    <div class="row"><span class="label">Email:</span> {{user.email}}</div>
    <div class="row"><span class="label">Edad:</span> {{user.age}}</div>

    <div class="actions">
      <a href="/productos">Productos</a>
      <a href="/api/sessions/logout">Cerrar sesión</a>
    </div>
  </div>
</body>
</html>
